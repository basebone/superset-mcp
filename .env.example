# Superset connection settings
SUPERSET_BASE_URL=http://localhost:8088
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin

# Optional: JWT token for direct token-based authentication
# SUPERSET_JWT_TOKEN=your_jwt_token_here

# Optional: Session cookie for OAuth-based authentication
# SUPERSET_SESSION_COOKIE=your_session_cookie_here

# Optional: Guest token configuration for embedded dashboards
# GUEST_TOKEN_JWT_SECRET=your_jwt_secret_here
# GUEST_TOKEN_JWT_AUDIENCE=your_audience_here
# GUEST_ROLE_NAME=your_guest_role_name

# ---------------------------------------------------------------------------
# HTTP transport settings (for remote MCP access via Claude, ChatGPT, etc.)
# ---------------------------------------------------------------------------
# MCP_TRANSPORT=streamable-http        # stdio | streamable-http | sse | both
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_PORT=8044
# MCP_ISSUER_URL=https://smcp.example.com

# OAuth clients — comma-separated "client_id:client_secret" pairs.
# Each client can be revoked independently by removing it from the list.
# MCP_OAUTH_CLIENTS=claude-ai:change-me-secret-1,chatgpt:change-me-secret-2

# Static API tokens for programmatic access (e.g. OpenAI agents SDK).
# Comma-separated. Clients pass as "Authorization: Bearer <token>".
# MCP_API_TOKENS=my-api-token-1,my-api-token-2

# TLS — omit when running behind a TLS-terminating load balancer (e.g. HAProxy).
# MCP_TLS_CERTFILE=/etc/letsencrypt/live/example.com/fullchain.pem
# MCP_TLS_KEYFILE=/etc/letsencrypt/live/example.com/privkey.pem

# IP allowlist — comma-separated CIDRs. Omit to allow all.
# MCP_ALLOWED_IPS=160.79.104.0/21,104.210.139.192/28

# Trusted proxies — when a request comes from one of these IPs,
# the real client IP is read from X-Forwarded-For.
# MCP_TRUSTED_PROXIES=127.0.0.1,10.0.0.1